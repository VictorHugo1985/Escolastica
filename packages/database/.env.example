# Plantilla de Configuración de Conexión a Base de Datos (Supabase + Prisma)
# Ver Spec 002: Diccionario de Datos

# URL de conexión con pooling (usada por Prisma Client en modo producción)
# Reemplazar con los valores de Supabase (Connection Pooling)
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"

# URL de conexión directa (usada por Prisma Migrate para cambios estructurales)
# Reemplazar con los valores de Supabase (Direct Connection)
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Credenciales de API de Supabase
SUPABASE_URL="https://[PROJECT_ID].supabase.co"
SUPABASE_ANON_KEY="[ANON_KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"
